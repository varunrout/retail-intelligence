# ── Data (large raw / processed files — not committed) ────────────────────
# Anchored to the repo-root data/ directory ONLY. An unanchored `data/` also
# matched src/data/, which silently excluded the entire src/data package from
# the repo (loaders, schemas, validators, phase runners) and broke every
# clone: imports, pytest collection and the pipeline runners.
/data/

# ── Python environment ─────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Testing / coverage ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── OS / editor artefacts ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo

# ── Secrets / env ─────────────────────────────────────────────────────────
.env
.env.*
secrets.json
