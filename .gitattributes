# Normalise line endings: store text as LF in the repo, check out LF everywhere.
# Prevents the whole-tree CRLF/LF churn that otherwise shows every file as modified.
* text=auto eol=lf

# Explicit binary types (never touch these bytes)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pkl binary
*.parquet binary
*.duckdb binary
*.duckdb.wal binary
*.ipynb binary
*.pdf binary
*.xlsx binary
